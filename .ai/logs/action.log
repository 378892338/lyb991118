{"ts":"2026-07-16T21:20:49.969Z","session":"07acf842-e481-4a07-a20a-e52c8a987347","tool":"Write","args_hash":"sha1:fa3bf78566d4f6a626d6a288eb9695d101d6d7d3","args_redacted":"{\"file_path\":\"<EXTERNAL_PATH>\",\"content\":\"import type { NextRequest } from \\\"next/server\\\";\\nimport fs from \\\"fs\\\";\\nimport path from \\\"path\\\";\\n\\nconst CONTENT_DIR = path.join(process.cwd(), \\\"content\\\");\\n\\n/**\\n * Decap CMS local proxy — handles file read/write for /admin\\n * Runs only in local dev (`npm run dev` + `local_backend: true`)\\n */\\nexport async function GET() {\\n  return Response.json({ message: \\\"Decap CMS proxy — POST to read/write files\\\" });\\n}\\n\\nexport async function POST(request: NextRequest) {\\n  try {\\n    const body = await request.json();\\n    const { action, branch, path: filePath, content, message } = body;\\n\\n    // Only allow content/ directory writes\\n    const fullPath = path.resolve(path.join(CONTENT_DIR, \\\"..\\\", filePath));\\n    if (!fullPath.startsWith(path.resolve(CONTENT_DIR))) {\\n      return Response.json({ error: \\\"Invalid path\\\" }, { status: 403 });\\n    }\\n\\n    // Read file\\n    if (action === \\\"getEntry\\\" || action === \\\"readFile\\\") {\\n      const dir = path.dirname(fullPath);\\n      if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });\\n      if (fs.existsSync(fullPath)) {\\n        return Response.json(fs.readFileSync(fullPath, \\\"utf-8\\\"));\\n      }\\n      return Response.json(\\\"\\\", { status: 404 });\\n    }\\n\\n    // Write file\\n    if (action === \\\"persistEntry\\\" || action === \\\"writeFile\\\") {\\n      const dir = path.dirname(fullPath);\\n      if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });\\n      fs.writeFileSync(fullPath, content, \\\"utf-8\\\");\\n      return Response.json({ message: \\\"ok\\\" });\\n    }\\n\\n    return Response.json({ error: `Unknown action: ${action}` }, { status: 400 });\\n  } catch (e: any) {\\n    return Response.json({ error: e.message }, { status: 500 });\\n  }\\n}\\n\"}","files":[],"exit_code":0,"duration_ms":75,"anchor_referenced":[]}
