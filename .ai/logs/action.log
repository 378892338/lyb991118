{"ts":"2026-07-16T22:28:58.747Z","session":"07acf842-e481-4a07-a20a-e52c8a987347","tool":"Edit","args_hash":"sha1:15ee56182d17c9a9b87bb7915e27a36942cffba8","args_redacted":"{\"file_path\":\"<EXTERNAL_PATH>\",\"old_string\":\"/* ── 公历转农历核心 ── */\\n\\nfunction solarToLunar(year: number, month: number, day: number) {\\n  const baseDate = Date.UTC(1900, 0, 31);\\n  const targetDate = Date.UTC(year, month - 1, day);\\n  let offset = (targetDate - baseDate) / 86400000;\\n\\n  let lunarYear = 0;\\n  let totalDays = 0;\\n  for (let i = 0; i < LUNAR_INFO.length; i++) {\\n    totalDays += LUNAR_INFO[i] & 0xfff;\\n    if (offset < totalDays) {\\n      lunarYear = 1900 + i;\\n      offset -= totalDays - (LUNAR_INFO[i] & 0xfff);\\n      break;\\n    }\\n  }\\n\\n  const yearInfo = LUNAR_INFO[lunarYear - 1900];\\n  let lunarMonth = 1;\\n  let lunarDay = 1;\\n  let isLeap = false;\\n  let monthSum = 0;\\n  const leapMonth = (yearInfo >> 12) & 0xf;\\n\\n  for (let m = 1; m <= 12; m++) {\\n    let monthDays = (yearInfo & (0x8000 >> (m - 1))) ? 30 : 29;\\n    if (offset < monthSum + monthDays && lunarMonth === m) {\\n      lunarDay = offset - monthSum + 1;\\n      break;\\n    }\\n    monthSum += monthDays;\\n    lunarMonth = m + 1;\\n\\n    // 闰月\\n    if (leapMonth === m) {\\n      const leapDays = (yearInfo & 0xf0000) ? 30 : 29;\\n      if (offset < monthSum + leapDays) {\\n        lunarDay = offset - monthSum + 1;\\n        isLeap = true;\\n        break;\\n      }\\n      monthSum += leapDays;\\n    }\\n  }\\n\\n  return { lunarYear, lunarMonth: lunarMonth <= 12 ? lunarMonth : 12, lunarDay: lunarDay || 1, isLeap };\\n}\",\"new_string\":\"/* ── 公历转农历核心 ── */\\n\\nfunction solarToLunar(year: number, month: number, day: number) {\\n  // 农历数据表每项含义（基于权威万年历数据）：\\n  //   bit 12-15: 闰月月份 (0 = 无闰月)\\n  //   bit 4-15 低 12 位: 当年农历总天数\\n  //   bit 15-(15-月份+1): 各月大小月 (1=大30天, 0=小29天)\\n  //   bit 16-19: 闰月大小 (1=大, 0=小)\\n\\n  // 计算从 1900-01-31 起的天数偏移\\n  const baseDate = Date.UTC(1900, 0, 31);\\n  const targetDate = Date.UTC(year, month - 1, day);\\n  const offsetDays = Math.floor((targetDate - baseDate) / 86400000);\\n\\n  if (offsetDays < 0) return { lunarYear: year, lunarMonth: 1, lunarDay: 1, isLeap: false };\\n\\n  // 1. 找农历年\\n  let i = 0;\\n  let total = 0;\\n  for (; i < LUNAR_INFO.length; i++) {\\n    const days = LUNAR_INFO[i] & 0xfff;\\n    if (total + days > offsetDays) break;\\n    total += days;\\n  }\\n  const lunarYear = 1900 + i;\\n  const yearInfo = LUNAR_INFO[i];\\n  const leapMonth = (yearInfo >> 12) & 0xf;\\n  let dayOfYear = offsetDays - total;\\n\\n  // 2. 在年内逐月找日\\n  let lunarMonth = 1;\\n  let isLeap = false;\\n\\n  for (let m = 1; m <= 12; m++) {\\n    // 本月天数\\n    const monthDays = (yearInfo & (0x8000 >> (m - 1))) ? 30 : 29;\\n\\n    if (dayOfYear < monthDays) {\\n      lunarMonth = m;\\n      break;\\n    }\\n    dayOfYear -= monthDays;\\n\\n    // 如果本月是闰月插入\\n    if (m === leapMonth) {\\n      const leapDays = (yearInfo & 0x10000) ? 30 : 29;\\n      if (dayOfYear < leapDays) {\\n        lunarMonth = m;\\n        isLeap = true;\\n        break;\\n      }\\n      dayOfYear -= leapDays;\\n    }\\n  }\\n\\n  return {\\n    lunarYear,\\n    lunarMonth,\\n    lunarDay: dayOfYear + 1,\\n    isLeap,\\n  };\\n}\",\"replace_all\":false}","files":[],"exit_code":0,"duration_ms":103,"anchor_referenced":[]}
