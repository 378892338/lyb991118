{"ts":"2026-07-16T19:18:35.228Z","session":"07acf842-e481-4a07-a20a-e52c8a987347","tool":"Write","args_hash":"sha1:8f83efa7133e4915c8e5b2fa5786d4b3d037ff26","args_redacted":"{\"file_path\":\"<EXTERNAL_PATH>\",\"content\":\"\\\"use client\\\";\\n\\nimport { useState, useRef, useEffect, useCallback } from \\\"react\\\";\\nimport { FAQ_LIST } from \\\"@/lib/faq\\\";\\nimport { ArrowUp } from \\\"lucide-react\\\";\\n\\ninterface Message {\\n  id: number;\\n  role: \\\"assistant\\\" | \\\"user\\\";\\n  text: string;\\n  isTyping?: boolean;\\n}\\n\\nconst TYPING_SPEED = 50; // ms per glyph\\n\\nexport default function ChatWindow({ onClose }: { onClose: () => void }) {\\n  const [messages, setMessages] = useState<Message[]>([]);\\n  const [input, setInput] = useState(\\\"\\\");\\n  const [isTyping, setIsTyping] = useState(false);\\n  const [focused, setFocused] = useState(false);\\n  const bottomRef = useRef<HTMLDivElement>(null);\\n  const inputRef = useRef<HTMLInputElement>(null);\\n\\n  useEffect(() => {\\n    bottomRef.current?.scrollIntoView({ behavior: \\\"smooth\\\" });\\n  }, [messages]);\\n\\n  const matchFAQ = useCallback((q: string): string | null => {\\n    const lower = q.trim().toLowerCase();\\n    if (!lower) return null;\\n    for (const faq of FAQ_LIST) {\\n      if (lower.includes(faq.question.slice(0, 3))) return faq.answer;\\n    }\\n    for (const faq of FAQ_LIST) {\\n      const kw = faq.question.slice(1, 5);\\n      if (lower.includes(kw)) return faq.answer;\\n    }\\n    return null;\\n  }, []);\\n\\n  const sendMessage = useCallback(\\n    (text: string) => {\\n      const trimmed = text.trim();\\n      if (!trimmed || isTyping) return;\\n      setIsTyping(true);\\n      setInput(\\\"\\\");\\n\\n      setMessages((prev) => [...prev, { id: Date.now() - 1, role: \\\"user\\\", text: trimmed }]);\\n\\n      const answer = matchFAQ(trimmed);\\n      const full =\\n        answer ??\\n        \\\"这个问题我暂时还不太确定怎么回答。试试看下面的快捷问题，或者去「About」「Contact」页面了解更多。\\\";\\n\\n      setTimeout(() => {\\n        const msgId = Date.now();\\n        setMessages((prev) => [...prev, { id: msgId, role: \\\"assistant\\\", text: \\\"\\\", isTyping: true }]);\\n        let i = 0;\\n        const timer = setInterval(() => {\\n          i++;\\n          setMessages((prev) =>\\n            prev.map((m) => (m.id === msgId ? { ...m, text: full.slice(0, i) } : m))\\n          );\\n          if (i >= full.length) {\\n            clearInterval(timer);\\n            setMessages((prev) =>\\n              prev.map((m) => (m.id === msgId ? { ...m, isTyping: false } : m))\\n            );\\n            setIsTyping(false);\\n          }\\n        }, TYPING_SPEED);\\n      }, 300);\\n    },\\n    [isTyping, matchFAQ]\\n  );\\n\\n  return (\\n    <>\\n      {/* 背板 — 淡暗色遮罩 */}\\n      <div\\n        className=\\\"fixed inset-0 z-40\\\"\\n        style={{ background: \\\"rgba(10,16,40,0.12)\\\" }}\\n        onClick={onClose}\\n      />\\n\\n      {/* 主面板 — 羊脂白玉质感 */}\\n      <div className=\\\"fixed inset-0 z-50 flex items-center justify-center p-4\\\">\\n        <div\\n          className=\\\"w-full max-w-[720px] rounded-3xl flex flex-col overflow-hidden animate-scale-in\\\"\\n          style={{\\n            maxHeight: \\\"min(600px, 85vh)\\\",\\n            background: \\\"linear-gradient(135deg, #FFFEF7 0%, #FDF8EE 50%, #FFFBF3 100%)\\\",\\n            border: \\\"1px solid rgba(180, 160, 120, 0.2)\\\",\\n            boxShadow: \\\"0 30px 60px rgba(0,0,0,0.08), 0 8px 20px rgba(0,0,0,0.04), inset 0 1px 0 rgba(255,255,255,0.9), inset 0 -1px 0 rgba(200,180,140,0.05)\\\",\\n          }}\\n        >\\n          {/* 顶栏 */}\\n          <div className=\\\"flex items-center justify-between px-6 py-4 border-b border-neutral-200/40\\\">\\n            <span className=\\\"text-sm font-semibold text-neutral-700\\\">Ask anything about Second Curve Lab</span>\\n            <button onClick={onClose} className=\\\"text-neutral-300 hover:text-neutral-500 transition-colors\\\" aria-label=\\\"关闭\\\">\\n              <svg width=\\\"18\\\" height=\\\"18\\\" viewBox=\\\"0 0 24 24\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" strokeWidth=\\\"2\\\">\\n                <path d=\\\"M18 6L6 18M6 6l12 12\\\" />\\n              </svg>\\n            </button>\\n          </div>\\n\\n          {/* 消息区 */}\\n          <div className=\\\"flex-1 overflow-y-auto px-6 py-5 space-y-4\\\">\\n            {messages.length === 0 && (\\n              <div className=\\\"text-center py-12\\\">\\n                <p className=\\\"text-lg font-medium text-neutral-500 mb-6\\\">你好，想了解什么？</p>\\n                <div className=\\\"flex flex-wrap justify-center gap-2\\\">\\n                  {FAQ_LIST.slice(0, 6).map((faq, i) => (\\n                    <button\\n                      key={i}\\n                      onClick={() => sendMessage(faq.question)}\\n                      className=\\\"text-sm px-4 py-2 rounded-full border border-neutral-200 text-neutral-600 bg-white/70 hover:border-neutral-300 hover:bg-white transition-colors\\\"\\n                    >\\n                      {faq.question}\\n                    </button>\\n                  ))}\\n                </div>\\n              </div>\\n            )}\\n            {messages.map((msg) => (\\n              <div key={msg.id} className={`flex ${msg.role === \\\"user\\\" ? \\\"justify-end\\\" : \\\"justify-start\\\"}`}>\\n                <div className={`max-w-[80%] px-4 py-2.5 text-sm leading-relaxed ${\\n                  msg.role === \\\"user\\\"\\n                    ? \\\"bg-neutral-800 text-white rounded-2xl rounded-br-md\\\"\\n                    : \\\"bg-white/80 text-neutral-700 rounded-2xl rounded-bl-md border border-neutral-200/40\\\"\\n                }`}>\\n                  {msg.text}\\n                  {msg.isTyping && <span className=\\\"inline-block w-1.5 h-4 bg-neutral-400 ml-0.5 animate-pulse rounded-full\\\" />}\\n                </div>\\n              </div>\\n            ))}\\n            <div ref={bottomRef} />\\n          </div>\\n\\n          {/* 输入区 — 羊脂白玉质感 */}\\n          <div className=\\\"px-6 py-4 border-t border-neutral-200/30\\\">\\n            <div\\n              className={`relative flex items-center w-full rounded-2xl transition-all duration-300 ${\\n                focused ? \\\"shadow-sm\\\" : \\\"\\\"\\n              }`}\\n              style={{\\n                background: \\\"linear-gradient(135deg, #FFFEF7 0%, #FDF8EE 50%, #FFFBF3 100%)\\\",\\n                border: focused\\n                  ? \\\"1px solid rgba(180, 160, 120, 0.25)\\\"\\n                  : \\\"1px solid rgba(180, 160, 120, 0.1)\\\",\\n                boxShadow: focused\\n                  ? \\\"inset 0 1px 0 rgba(255,255,255,0.8)\\\"\\n                  : \\\"inset 0 1px 0 rgba(255,255,255,0.6)\\\",\\n              }}\\n            >\\n              <input\\n                ref={inputRef}\\n                type=\\\"text\\\"\\n                value={input}\\n                onChange={(e) => setInput(e.target.value)}\\n                onKeyDown={(e) => { if (e.key === \\\"Enter\\\") sendMessage(input); }}\\n                onFocus={() => setFocused(true)}\\n                onBlur={() => setFocused(false)}\\n                placeholder=\\\"问点什么…\\\"\\n                disabled={isTyping}\\n                className=\\\"flex-1 bg-transparent px-5 py-3.5 text-sm text-neutral-800 placeholder-neutral-300 outline-none disabled:opacity-40\\\"\\n              />\\n              <button\\n                onClick={() => sendMessage(input)}\\n                disabled={!input.trim() || isTyping}\\n                className=\\\"mr-2 w-9 h-9 rounded-xl bg-neutral-800/90 text-white flex items-center justify-center hover:bg-neutral-900 transition-colors disabled:opacity-25 disabled:cursor-not-allowed shadow-sm\\\"\\n              >\\n                <ArrowUp size={16} />\\n              </button>\\n            </div>\\n          </div>\\n        </div>\\n      </div>\\n    </>\\n  );\\n}\"}","files":[],"exit_code":0,"duration_ms":26,"anchor_referenced":[]}
