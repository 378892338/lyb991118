{"ts":"2026-07-16T18:38:23.616Z","session":"07acf842-e481-4a07-a20a-e52c8a987347","tool":"Write","args_hash":"sha1:fe32b0ba121cdc302aaa174bee2f4021ec80ac24","args_redacted":"{\"file_path\":\"<EXTERNAL_PATH>\",\"content\":\"@import \\\"tailwindcss\\\";\\n\\n@source \\\"../../content/\\\";\\n\\n@theme inline {\\n  /* ── 品牌绿（保留） ── */\\n  --color-brand-50: #e6f7f3;\\n  --color-brand-100: #ccefe7;\\n  --color-brand-200: #99dfcf;\\n  --color-brand-300: #66cfb7;\\n  --color-brand-400: #33bf9f;\\n  --color-brand-500: #0d9373;\\n  --color-brand-600: #0a755c;\\n  --color-brand-700: #075745;\\n  --color-brand-800: #053a2e;\\n  --color-brand-900: #021d17;\\n\\n  /* ── 晨空色系 ── */\\n  --color-ds-night-900: #0a0a2e;\\n  --color-ds-night-800: #0d0d38;\\n  --color-ds-night-700: #1a184a;\\n  --color-ds-night-600: #221f5e;\\n  --color-ds-twilight-500: #3b2d65;\\n  --color-ds-twilight-400: #4e3e72;\\n  --color-ds-twilight-300: #5c4a7e;\\n  --color-ds-dawn-400: #c4846e;\\n  --color-ds-dawn-300: #d49e83;\\n  --color-ds-dawn-200: #e8c4a2;\\n  --color-ds-dawn-100: #f0dcc8;\\n  --color-ds-sky-100: #f5f0eb;\\n  --color-ds-sky-50: #fafaf8;\\n\\n  /* ── 中性色（暖调 Apple） ── */\\n  --color-neutral-0: #ffffff;\\n  --color-neutral-50: #f5f5f7;\\n  --color-neutral-100: #e8e8ed;\\n  --color-neutral-200: #d2d2d7;\\n  --color-neutral-300: #aeaeb2;\\n  --color-neutral-400: #86868b;\\n  --color-neutral-500: #6e6e73;\\n  --color-neutral-600: #515154;\\n  --color-neutral-700: #3a3a3c;\\n  --color-neutral-800: #2c2c2e;\\n  --color-neutral-900: #1d1d1f;\\n\\n  /* ── 字体 ── */\\n  --font-sans: -apple-system, \\\"SF Pro Text\\\", \\\"Helvetica Neue\\\", \\\"PingFang SC\\\",\\n    \\\"Noto Sans CJK SC\\\", \\\"Microsoft YaHei\\\", sans-serif;\\n  --font-mono: \\\"SF Mono\\\", \\\"Fira Code\\\", \\\"Consolas\\\", monospace;\\n  --font-kai: \\\"KaiTi\\\", \\\"STKaiti\\\", \\\"FangSong\\\", \\\"Noto Serif CJK SC\\\", \\\"SimSun\\\", serif;\\n\\n  /* ── 动画 ── */\\n  --animate-fade-in-up: fade-in-up 0.6s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;\\n  --animate-fade-in: fade-in 0.5s ease-out forwards;\\n  --animate-scale-in: scale-in 0.3s ease-out forwards;\\n  --animate-twinkle: twinkle 3s ease-in-out infinite;\\n  --animate-cloud-drift: cloud-drift 10s ease-in-out alternate infinite;\\n  --animate-float: gentle-float 6s ease-in-out infinite;\\n\\n  @keyframes fade-in-up {\\n    from { opacity: 0; transform: translateY(20px); }\\n    to { opacity: 1; transform: translateY(0); }\\n  }\\n  @keyframes fade-in {\\n    from { opacity: 0; }\\n    to { opacity: 1; }\\n  }\\n  @keyframes scale-in {\\n    from { opacity: 0; transform: scale(0.95); }\\n    to { opacity: 1; transform: scale(1); }\\n  }\\n  @keyframes twinkle {\\n    0%, 100% { opacity: 0.3; }\\n    50% { opacity: 0.8; }\\n  }\\n  @keyframes cloud-drift {\\n    from { transform: translateX(-30px); }\\n    to { transform: translateX(30px); }\\n  }\\n  @keyframes gentle-float {\\n    0%, 100% { transform: translateY(0) rotateZ(2deg); }\\n    50% { transform: translateY(-6px) rotateZ(1deg); }\\n  }\\n}\\n\\n/* ── 基础重置 ── */\\n* { box-sizing: border-box; }\\nhtml { scroll-behavior: smooth; }\\n\\nbody {\\n  background: var(--color-ds-sky-50);\\n  color: var(--color-neutral-900);\\n  font-family: var(--font-sans);\\n  -webkit-font-smoothing: antialiased;\\n  -moz-osx-font-smoothing: grayscale;\\n}\\n\\n/* ── Scrollbar ── */\\n::-webkit-scrollbar { width: 6px; }\\n::-webkit-scrollbar-track { background: transparent; }\\n::-webkit-scrollbar-thumb { background: var(--color-neutral-300); border-radius: 3px; }\\n::-webkit-scrollbar-thumb:hover { background: var(--color-neutral-400); }\\n\\n/* ── 语法高亮 ── */\\n@import \\\"highlight.js/styles/github-dark-dimmed.css\\\";\\n\\n/* ═══════════════════════════════════════════\\n   晨空天空系统\\n   ═══════════════════════════════════════════ */\\n\\n/* 全局天空背景渐变（Hero 用，向下逐渐淡出） */\\n.dawn-sky-bg {\\n  background:\\n    radial-gradient(ellipse 80% 60% at 50% 20%, rgba(59, 45, 101, 0.15) 0%, transparent 70%),\\n    linear-gradient(180deg,\\n      var(--color-ds-night-900) 0%,\\n      var(--color-ds-night-700) 18%,\\n      var(--color-ds-twilight-500) 35%,\\n      var(--color-ds-dawn-400) 55%,\\n      var(--color-ds-dawn-200) 72%,\\n      var(--color-ds-sky-100) 88%,\\n      var(--color-ds-sky-50) 100%\\n    );\\n  transition: filter 0.3s ease-out;\\n}\\n\\n/* ── 星星 ── */\\n.star {\\n  position: absolute;\\n  width: 2px;\\n  height: 2px;\\n  border-radius: 50%;\\n  background: #fff;\\n  animation: var(--animate-twinkle);\\n  pointer-events: none;\\n}\\n\\n/* ── 月亮 ── */\\n.dawn-moon {\\n  position: absolute;\\n  top: 8%;\\n  right: 12%;\\n  width: 120px;\\n  height: 120px;\\n  pointer-events: none;\\n  filter: drop-shadow(0 0 30px rgba(255, 235, 200, 0.3));\\n}\\n\\n/* ── 淡云 ── */\\n.dawn-cloud {\\n  position: absolute;\\n  height: 40px;\\n  border-radius: 9999px;\\n  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.06) 30%, rgba(255, 255, 255, 0.1) 50%, rgba(255, 255, 255, 0.06) 70%, transparent);\\n  animation: var(--animate-cloud-drift);\\n  pointer-events: none;\\n}\\n\\n/* ═══════════════════════════════════════════\\n   老黄历飘页\\n   ═══════════════════════════════════════════ */\\n\\n.almanac-card {\\n  position: absolute;\\n  width: 280px;\\n  height: 380px;\\n  background: #f5ecd7;\\n  background-image: url(\\\"data:image/svg+xml,%3Csvg width='280' height='380' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E\\\");\\n  border: 1px solid rgba(139, 119, 80, 0.15);\\n  border-radius: 4px;\\n  box-shadow:\\n    0 2px 8px rgba(40, 25, 10, 0.08),\\n    0 8px 32px rgba(40, 25, 10, 0.06);\\n  writing-mode: vertical-rl;\\n  color: #3d2b1f;\\n  font-family: var(--font-kai);\\n  padding: 24px 16px;\\n  pointer-events: auto;\\n  user-select: none;\\n  z-index: 100;\\n}\\n.almanac-card::before {\\n  content: \\\"\\\";\\n  position: absolute;\\n  inset: 8px;\\n  border: 1px solid rgba(139, 119, 80, 0.08);\\n  border-radius: 2px;\\n  pointer-events: none;\\n}\\n\\n/* 阳历日期（右上角） */\\n.almanac-solar {\\n  position: absolute;\\n  top: 14px;\\n  right: 18px;\\n  writing-mode: horizontal-tb;\\n  font-size: 13px;\\n  font-weight: 700;\\n  color: #c41e3a;\\n  letter-spacing: 1px;\\n}\\n\\n/* 竖排正文 */\\n.almanac-body {\\n  display: flex;\\n  flex-direction: column;\\n  align-items: center;\\n  gap: 18px;\\n  margin: 20px 0;\\n  font-size: 16px;\\n  line-height: 2;\\n  letter-spacing: 2px;\\n}\\n.almanac-body .label {\\n  font-size: 11px;\\n  color: #8b7750;\\n  letter-spacing: 4px;\\n  margin-bottom: 2px;\\n}\\n.almanac-body .yi-items,\\n.almanac-body .ji-items {\\n  display: flex;\\n  flex-wrap: wrap;\\n  gap: 4px;\\n  justify-content: center;\\n}\\n\\n/* ── 印章 ── */\\n.almanac-seal {\\n  position: absolute;\\n  bottom: 20px;\\n  right: 18px;\\n  width: 56px;\\n  height: 56px;\\n  border: 2.5px solid #c41e3a;\\n  border-radius: 3px;\\n  color: #c41e3a;\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  writing-mode: horizontal-tb;\\n  filter: url(#seal-texture);\\n}\\n.almanac-seal .seal-text {\\n  font-size: 12px;\\n  font-weight: 700;\\n  line-height: 1.3;\\n  text-align: center;\\n  letter-spacing: 1px;\\n}\\n\\n/* ═══════════════════════════════════════════\\n   聊天窗\\n   ═══════════════════════════════════════════ */\\n\\n.chat-window {\\n  position: fixed;\\n  bottom: 90px;\\n  right: 24px;\\n  width: 340px;\\n  max-height: 480px;\\n  background: var(--color-neutral-0);\\n  border-radius: 16px;\\n  border: 1px solid var(--color-neutral-100);\\n  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08), 0 0 0 1px rgba(0, 0, 0, 0.03);\\n  display: flex;\\n  flex-direction: column;\\n  overflow: hidden;\\n  z-index: 99;\\n  animation: var(--animate-scale-in);\\n}\\n\\n/* 黄历小标签（悬停聊天按钮时出现） */\\n.almanac-teaser {\\n  position: fixed;\\n  bottom: 90px;\\n  right: 72px;\\n  padding: 6px 14px;\\n  background: #f5ecd7;\\n  color: #3d2b1f;\\n  font-family: var(--font-kai);\\n  font-size: 13px;\\n  border-radius: 20px;\\n  box-shadow: 0 2px 8px rgba(40, 25, 10, 0.1);\\n  animation: var(--animate-fade-in-up);\\n  pointer-events: none;\\n  z-index: 98;\\n}\\n\"}","files":[],"exit_code":0,"duration_ms":144,"anchor_referenced":[]}
